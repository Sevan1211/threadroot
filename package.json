    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0"
